@startuml SmartHomeClassDiagram

title Smart Home Automation\nCSE3202 / SE 491 — 9 design patterns

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam packageFontSize 12
skinparam packageStyle rectangle
skinparam linetype polyline
skinparam nodesep 50
skinparam ranksep 50
skinparam classBackgroundColor #FFFFFF
skinparam stereotypeCBackgroundColor #FFD99C
skinparam stereotypeIBackgroundColor #B8D8E8
skinparam packageBackgroundColor #F8F9FB
skinparam packageBorderColor #1F2940

' ═════════════════════════════════════════════════════════════
' DOMAIN
' ═════════════════════════════════════════════════════════════

package "core" {
    class SmartHomeHub <<Singleton>> {
        - INSTANCE : SmartHomeHub {static}
        + getInstance() {static}
        + addRoom(Room)
        + setAutomationMode(AutomationMode)
        + applyAutomationMode()
        + createIterator() : RoomIterator
    }

    class Room {
        + addDevice(Device)
        + devices() : Enumeration<Device>
    }

    interface RoomIterator <<Iterator>> {
        + hasMore()
        + getNext()
    }
    class HubRoomIterator
}

package "observer" {
    interface Observer <<Observer>> {
        + update(Device, String)
    }
    interface Observable <<Subject>>
}

package "devices" {
    abstract class Device {
        - observers : List<Observer>
        + turnOn() / turnOff()
        + attach / detach / notifyObservers
    }
    class Light
    class Thermostat
    class Lock
    class Camera

    package "version1/version2" as variants {
        class "Version1Light\nVersion1Thermostat\nVersion1Lock\nVersion1Camera" as V1
        class "Version2Light\nVersion2Thermostat\nVersion2Lock\nVersion2Camera" as V2
    }

    package "decorator" {
        abstract class DeviceDecorator <<Decorator>> {
            # wrappee : Device
        }
        class LoggingDeviceDecorator
        class EnergyTrackedDecorator
    }
}

package "factory" {
    abstract class DeviceFactory <<Abstract Factory>> {
        + {abstract} createLight()
        + {abstract} createThermostat()
        + {abstract} createDoorLock()
        + {abstract} createCamera()
    }
    class Version1DeviceFactory
    class Version2DeviceFactory
}

package "strategy" {
    interface AutomationMode <<Strategy>> {
        + name()
        + apply(SmartHomeHub)
    }
    class EcoMode
    class SleepMode
    class AwayMode
}

' ═════════════════════════════════════════════════════════════
' APPLICATION
' ═════════════════════════════════════════════════════════════

package "command" {
    interface DeviceCommand <<Command>> {
        + execute()
        + undo()
        + describe()
    }
    class "TurnOn\nTurnOff\nSetTemperature\nLock\nUnlock\nSetAutomationMode\nCommand" as Cmds
    class CommandInvoker <<Invoker>> {
        - history : Deque<DeviceCommand>
        + execute(DeviceCommand)
        + undo() : DeviceCommand
    }
}

package "facade" {
    class HomeController <<Facade>> {
        + turnOnDevice / turnOffDevice
        + lockDevice / unlockDevice
        + setTemperature
        + setAutomationMode
        + getDevicesForRoom
        + getEventHistory
        + undoLastAction()
    }
}

' ═════════════════════════════════════════════════════════════
' PERSISTENCE
' ═════════════════════════════════════════════════════════════

package "persistence" {
    class Database <<Singleton>> {
        + getInstance() {static}
        + getConnection()
    }
    package "dao" {
        class "UserDAO\nRoomDAO\nDeviceDAO\nDeviceEventDAO\nCommandsLogDAO" as DAOs <<DAO>>
    }
}

' ═════════════════════════════════════════════════════════════
' UI
' ═════════════════════════════════════════════════════════════

package "ui" {
    class App
    class DaoEventBridge <<Observer adapter>>
}

' ═════════════════════════════════════════════════════════════
' RELATIONSHIPS — only the essentials
' ═════════════════════════════════════════════════════════════

' Inheritance — devices
Light --|> Device
Thermostat --|> Device
Lock --|> Device
Camera --|> Device
V1 --|> Device : "extends"
V2 --|> Device : "extends"

' Decorators
DeviceDecorator --|> Device
LoggingDeviceDecorator --|> DeviceDecorator
EnergyTrackedDecorator --|> DeviceDecorator
DeviceDecorator o-- Device : wraps

' Factories
Version1DeviceFactory --|> DeviceFactory
Version2DeviceFactory --|> DeviceFactory
Version1DeviceFactory ..> V1 : creates
Version2DeviceFactory ..> V2 : creates

' Strategy
EcoMode ..|> AutomationMode
SleepMode ..|> AutomationMode
AwayMode ..|> AutomationMode
SmartHomeHub --> AutomationMode : current

' Iterator
HubRoomIterator ..|> RoomIterator
SmartHomeHub --> HubRoomIterator : creates

' Observer
Device ..|> Observable
DaoEventBridge ..|> Observer
Device o-- Observer

' Command
Cmds ..|> DeviceCommand
CommandInvoker o-- DeviceCommand : history
Cmds ..> Device : receiver

' Composition
SmartHomeHub o-- Room
Room o-- Device

' Facade dependencies
HomeController --> SmartHomeHub
HomeController --> CommandInvoker
HomeController --> DAOs

' DAO ↔ Database
DAOs --> Database

' DeviceDAO uses Abstract Factory at runtime
DAOs ..> DeviceFactory : "deserializes via"

' UI wiring
App --> SmartHomeHub : seeds
App --> Database : initialises
App --> DaoEventBridge : attaches to devices
DaoEventBridge --> DAOs

@enduml
