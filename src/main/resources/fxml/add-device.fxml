<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
  Modal dialog for adding a new device to a room.
  Demonstrates the Abstract Factory pattern at runtime:
    user picks (type, family) → corresponding factory method runs
    → device is created, persisted via DeviceDAO, and added to the room.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smarthome.ui.AddDeviceController"
      styleClass="content-pane"
      spacing="14"
      prefWidth="320">

  <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

  <Label fx:id="titleLabel" text="Add a device"
         styleClass="decorator-section-title"/>

  <Label text="Pattern in action: Abstract Factory + DAO"
         styleClass="pattern-caption" wrapText="true"/>

  <Label text="Device type" styleClass="room-name"/>
  <ChoiceBox fx:id="typeChoice" maxWidth="Infinity"/>

  <Label text="Family" styleClass="room-name"/>
  <ChoiceBox fx:id="familyChoice" maxWidth="Infinity"/>

  <Label text="Name" styleClass="room-name"/>
  <TextField fx:id="nameField" promptText="e.g. Bedside Lamp"/>

  <Label fx:id="errorLabel" styleClass="pattern-caption"
         wrapText="true" text=""/>

  <HBox spacing="10">
    <Button text="Cancel" onAction="#onCancel"
            styleClass="action-button"
            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button text="Add device" onAction="#onAdd"
            styleClass="action-button-primary, action-button"
            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
  </HBox>
</VBox>
