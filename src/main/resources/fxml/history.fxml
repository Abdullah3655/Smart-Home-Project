<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<!--
  History screen — newest-first feed of device events.
  Combines events from DeviceEventDAO (past sessions) and live Observer
  callbacks (current session).
-->
<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthome.ui.HistoryController"
            styleClass="main-scroll"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED">

  <content>
    <VBox fx:id="eventsContainer" styleClass="content-pane" spacing="8">
      <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

      <Label text="Recent device events" styleClass="decorator-section-title"/>
      <Label text="Persisted via the DAO pattern — survive app restart"
             styleClass="pattern-caption" wrapText="true"/>

      <!-- Event rows are appended here at runtime by HistoryController. -->
    </VBox>
  </content>

</ScrollPane>
