<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Mobile-styled root layout (~400×800).
  Owns the top bar, mode picker, status banner, and bottom nav.
  Center pane swaps between Home / History / Decorator screens.
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthome.ui.MainController"
            prefWidth="400" prefHeight="800">

  <top>
    <VBox>
      <!-- Top bar: title + undo -->
      <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="0">
        <Label styleClass="app-title-amber" text="●  "/>
        <Label styleClass="app-title" text="Smart Home"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button fx:id="undoButton" styleClass="undo-button"
                text="↶  Undo" onAction="#onUndo"/>
      </HBox>

      <!-- Mode picker: segmented buttons (auto-applies on tap) -->
      <VBox styleClass="mode-row">
        <Label text="AUTOMATION"/>
        <HBox spacing="0">
          <Button fx:id="modeEcoButton"
                  styleClass="mode-segment, mode-segment-first"
                  text="ECO" onAction="#onModeEco"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
          <Button fx:id="modeSleepButton"
                  styleClass="mode-segment"
                  text="SLEEP" onAction="#onModeSleep"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
          <Button fx:id="modeAwayButton"
                  styleClass="mode-segment, mode-segment-last"
                  text="AWAY" onAction="#onModeAway"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>
      </VBox>

      <!-- Status banner: hidden by default, slides in on actions -->
      <HBox fx:id="statusBanner" styleClass="status-banner"
            alignment="CENTER_LEFT" managed="false" visible="false">
        <Label fx:id="statusBannerText" styleClass="status-banner-text"
               text=""/>
      </HBox>
    </VBox>
  </top>

  <!-- Center: hosts the active screen (Home / History / Decorator) -->
  <center>
    <StackPane fx:id="screenHost" styleClass="content-pane"/>
  </center>

  <!-- Bottom nav -->
  <bottom>
    <HBox styleClass="bottom-nav" alignment="CENTER" spacing="0">
      <Button fx:id="navHomeButton"
              styleClass="nav-button, nav-button-active"
              text="Home"
              onAction="#onNavHome"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">
        <graphic>
          <Label styleClass="nav-icon" text="🏠"/>
        </graphic>
      </Button>
      <Button fx:id="navHistoryButton"
              styleClass="nav-button"
              text="History"
              onAction="#onNavHistory"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">
        <graphic>
          <Label styleClass="nav-icon" text="📋"/>
        </graphic>
      </Button>
      <Button fx:id="navDecoratorButton"
              styleClass="nav-button"
              text="Demo"
              onAction="#onNavDecorator"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">
        <graphic>
          <Label styleClass="nav-icon" text="🎁"/>
        </graphic>
      </Button>
    </HBox>
  </bottom>

</BorderPane>
